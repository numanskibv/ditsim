# ─────────────────────────────────────────────────────────────────────────────
# Secrets voor de Docker-PRODUCTIESTACK (docker compose) op de nuc.
#
# Kopieer dit bestand op de nuc naar .env en vul echte waarden in:
#
#     cp .env.docker.example .env
#
# Het echte .env staat in .gitignore en komt NOOIT in git. Alle NIET-geheime
# productie-instellingen (APP_URL, APP_ENV, domein, poorten) staan al direct in
# docker-compose.yml — hier horen ALLEEN de wachtwoorden/secrets.
#
# Na het invullen: docker compose up --build -d
# ─────────────────────────────────────────────────────────────────────────────

# Laravel app key. Genereer eenmalig een verse key met:
#   docker compose run --rm app php artisan key:generate --show
# (of lokaal: php artisan key:generate --show) en plak de base64:... hier.
APP_KEY=

# Database-wachtwoord. Geldt voor ZOWEL de Postgres-container als de app —
# één waarde, beide kanten gebruiken DB_PASSWORD. Kies een sterk wachtwoord.
DB_PASSWORD=

# Wachtwoord voor (demo)accounts wanneer SEED_DEMO=true. Bij een schone start
# (SEED_DEMO=false) niet gebruikt, maar wel verplicht ingevuld. Kies sterk.
DEFAULT_ACCOUNT_PASSWORD=

# Reverb websocket-credentials. Verzin eigen willekeurige waarden (de KEY komt
# in de browser-JS terecht; ID en SECRET horen geheim te blijven).
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
